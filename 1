"""
Runtime Capture ingestion — the Python half of Capture Mode.

The Java hook (tools/OrchestratorCaptureHook.java, installed once in the
framework) writes screenshot + page.html + meta.json per step into the job's
capture folder whenever the orchestrator passes -Dorchestrator.capture.dir.
This module: (1) indexes those captures per job, (2) mines each captured
page's DOM for element facts (inputs, buttons, selects with their ids/names/
placeholders/labels) and derives stable locators via the SAME derivation
engine as the recorder — auto-growing the Locator Knowledge Repository from
every capture run, and (3) supplies the failing screen's HTML as evidence for
the AI self-healing flow.
"""
import json
import re
from html.parser import HTMLParser
from pathlib import Path

from . import config, recorder

CAPTURE_ROOT_NAME = "runtime_capture"

_INTERESTING = {"input", "select", "button", "textarea", "a"}


class _FactsParser(HTMLParser):
    def __init__(self):
        super().__init__(convert_charrefs=True)
        self.facts: list[dict] = []
        self._open: dict | None = None
        self.title = ""
        self._in_title = False

    def handle_starttag(self, tag, attrs):
        if tag == "title":
            self._in_title = True
        if tag in _INTERESTING:
            a = {k: (v or "") for k, v in attrs}
            fact = {"tag": tag, "type": (a.get("type") or "").lower(),
                    "attrs": {k: v for k, v in a.items() if k != "value" and v},
                    "text": "", "ancestors": []}
            if tag in ("input",):                       # self-closing-ish: record now
                self.facts.append(fact)
            else:
                self._open = fact

    def handle_data(self, data):
        if self._in_title:
            self.title += data
        if self._open is not None:
            self._open["text"] = (self._open["text"] + " " + data.strip()).strip()[:80]

    def handle_endtag(self, tag):
        if tag == "title":
            self._in_title = False
        if self._open is not None and tag == self._open["tag"]:
            self.facts.append(self._open)
            self._open = None


def extract_screen_facts(html: str) -> dict:
    """{title, elements:[...recorder-shaped events...]} from a captured page."""
    p = _FactsParser()
    try:
        p.feed(html)
    except Exception:  # noqa: BLE001 — real-world HTML is messy; keep what parsed
        pass
    # keep only elements with SOMETHING identifiable
    elements = [f for f in p.facts
                if f["attrs"].get("id") or f["attrs"].get("name")
                or f["attrs"].get("placeholder") or f["attrs"].get("data-testid")
                or (f["text"] and f["tag"] in ("button", "a"))]
    return {"title": p.title.strip(), "elements": elements}


def capture_dir_for(job_id: str) -> Path:
    return config.DATA_DIR / CAPTURE_ROOT_NAME / job_id


def ingest(job_id: str, log=lambda m: None) -> dict:
    """Index a finished capture run: per-checkpoint metadata + mine every
    captured page into the locator repository (deduped by the repository)."""
    root = capture_dir_for(job_id)
    if not root.exists():
        return {"checkpoints": 0, "locators_added": 0}
    checkpoints, entries = [], []
    for folder in sorted(root.iterdir()):
        if not folder.is_dir():
            continue
        meta = {}
        mf = folder / "meta.json"
        if mf.exists():
            try:
                meta = json.loads(mf.read_text(encoding="utf-8", errors="ignore"))
            except Exception:  # noqa: BLE001
                pass
        html_file = folder / "page.html"
        title = meta.get("title", "")
        if html_file.exists():
            facts = extract_screen_facts(html_file.read_text(encoding="utf-8", errors="ignore"))
            title = title or facts["title"]
            for el in facts["elements"]:
                cands = recorder.derive_locators(el)
                if cands and cands[0]["locator_type"] != "xpath-fragile":
                    entries.append({"name": recorder.suggest_name(el),
                                    "java": cands[0]["java"],
                                    "locator_type": cands[0]["locator_type"],
                                    "locator_value": cands[0]["locator_value"],
                                    "screen": title or meta.get("url", ""),
                                    "source": "capture"})
        checkpoints.append({"folder": folder.name, "scenario": meta.get("scenario", ""),
                            "failed": meta.get("failed", False), "url": meta.get("url", ""),
                            "title": title,
                            "has_screenshot": (folder / "screenshot.png").exists(),
                            "has_html": html_file.exists()})
    added = recorder.save_entries(entries) if entries else 0
    if checkpoints:
        log(f">>> Capture: {len(checkpoints)} checkpoint(s) ingested, "
            f"{added} new locator(s) mined into the repository.")
    (root / "index.json").write_text(json.dumps(checkpoints, indent=1))
    return {"checkpoints": len(checkpoints), "locators_added": added}


def failing_evidence(job_id: str, cap_chars: int = 14000) -> dict | None:
    """The LAST failed checkpoint's HTML + metadata — the AI's evidence for
    healing. None when no failed capture exists."""
    root = capture_dir_for(job_id)
    if not root.exists():
        return None
    failed = [d for d in sorted(root.iterdir()) if d.is_dir() and d.name.endswith("_FAILED")]
    target = failed[-1] if failed else None
    if target is None:
        dirs = [d for d in sorted(root.iterdir()) if d.is_dir()]
        target = dirs[-1] if dirs else None
    if target is None or not (target / "page.html").exists():
        return None
    meta = {}
    try:
        meta = json.loads((target / "meta.json").read_text(encoding="utf-8", errors="ignore"))
    except Exception:  # noqa: BLE001
        pass
    html = (target / "page.html").read_text(encoding="utf-8", errors="ignore")
    # SECURITY (banking): redact every input value — esp. passwords/account
    # numbers — before this DOM reaches the AI prompt or any log. Reuse the
    # proven sanitizer rather than duplicating the regexes.
    try:
        from .capture import _sanitize_html
        html = _sanitize_html(html)
    except Exception:  # noqa: BLE001 — never let sanitize failure serve raw html
        html = re.sub(r'(<input\b[^>]*?\bvalue=)"[^"]*"', r'\1"[REDACTED]"', html, flags=re.I)
    # trim scripts/styles to fit the prompt budget while keeping structure
    html = re.sub(r"<script\b.*?</script>", "", html, flags=re.S | re.I)
    html = re.sub(r"<style\b.*?</style>", "", html, flags=re.S | re.I)
    return {"checkpoint": target.name, "meta": meta, "html": html[:cap_chars],
            "screenshot": str(target / "screenshot.png") if (target / "screenshot.png").exists() else None}
