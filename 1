package com.nbc.stepDefinitions.common;

import io.cucumber.java.AfterStep;
import io.cucumber.java.Scenario;
import org.openqa.selenium.OutputType;
import org.openqa.selenium.TakesScreenshot;
import org.openqa.selenium.WebDriver;

import java.nio.charset.StandardCharsets;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;

/**
 * ORCHESTRATOR CAPTURE HOOK — install ONCE, then never touch again.
 *
 * Completely inert during normal runs: only activates when the orchestrator
 * launches java with -Dorchestrator.capture.dir=<folder>. Captures screenshot
 * + full HTML + metadata after every step (or failures only, if
 * -Dorchestrator.capture.all=false), into that folder — the runtime evidence
 * the AI uses for locator discovery and self-healing.
 *
 * INSTALL (one manual edit, marked below):
 * 1. Save this file as src/test/java/com/nbc/stepDefinitions/common/OrchestratorCaptureHook.java
 * 2. Fix the ONE line marked TODO to use YOUR framework's driver accessor —
 *    open CommonSteps.java and copy however IT gets the WebDriver
 *    (e.g. BaseTest.getDriver() / DriverFactory.getDriver() / a shared field).
 * 3. Ctrl+F9 (Build Project). Done — normal runs are unaffected.
 */
public class OrchestratorCaptureHook {

    private static int counter = 0;

    @AfterStep
    public void captureAfterStep(Scenario scenario) {
        String dir = System.getProperty("orchestrator.capture.dir", "");
        if (dir.isEmpty()) return;                                     // normal run: inert
        boolean all = Boolean.parseBoolean(System.getProperty("orchestrator.capture.all", "true"));
        if (!all && !scenario.isFailed()) return;                      // failures-only mode
        try {
            // ── TODO (the ONE line to adapt): your framework's driver accessor ──
            WebDriver driver = com.nbc.base.BaseTest.getDriver();
            // ────────────────────────────────────────────────────────────────────
            if (driver == null) return;
            counter++;
            String safe = scenario.getName().replaceAll("[^A-Za-z0-9]+", "_");
            if (safe.length() > 60) safe = safe.substring(0, 60);
            Path folder = Paths.get(dir, String.format("%03d_%s%s", counter, safe,
                    scenario.isFailed() ? "_FAILED" : ""));
            Files.createDirectories(folder);
            Files.write(folder.resolve("page.html"),
                    driver.getPageSource().getBytes(StandardCharsets.UTF_8));
            try {
                byte[] png = ((TakesScreenshot) driver).getScreenshotAs(OutputType.BYTES);
                Files.write(folder.resolve("screenshot.png"), png);
            } catch (Exception ignored) { }
            String meta = String.format(
                    "{\"scenario\":\"%s\",\"failed\":%s,\"url\":\"%s\",\"title\":\"%s\",\"ts\":%d}",
                    scenario.getName().replace("\"", "'"), scenario.isFailed(),
                    driver.getCurrentUrl().replace("\"", "'"),
                    driver.getTitle().replace("\"", "'"), System.currentTimeMillis());
            Files.write(folder.resolve("meta.json"), meta.getBytes(StandardCharsets.UTF_8));
        } catch (Exception ignored) {
            // capture must NEVER break a test run
        }
    }
}
