"""
Locator Discovery Gate (spec: locator resolution is MANDATORY before code
generation; under strict policy, halt if locators can't be found).

This does NOT itself find element-level locators for arbitrary steps — that is
what generation + the repository + capture do. Its job is the GATE decision:
given the new/undefined steps that will need Java, decide whether the framework
already has enough locator knowledge to implement them WITHOUT inventing
guesses, and if not, stop and report exactly what's missing.

Resolution sources checked, in order (all already built):
  1. Locator repository (recorder-captured, human-verified locators)
  2. Runtime capture DOM for this txn (Capture Mode)
  3. Existing page-object locators for the txn's module (framework_scanner)

A step is considered "UI-interacting" (needs a locator) if its wording implies
a screen action — click/enter/select/verify-on-screen etc. Pure navigation or
data-setup steps that reuse existing glue don't need new locators.
"""
import re

from . import config

# words that imply the step touches a UI element (needs a locator)
_UI_VERBS = re.compile(
    r"\b(click|enter|select|type|choose|check|uncheck|tick|upload|input|fill|"
    r"press|toggle|set|search|view|see|verify|validate|confirm|display|"
    r"dropdown|button|field|screen|tile|checkbox|radio|link|tab|menu)\b", re.I)

# steps that are clearly NOT new UI interactions (login/logout/navigation that
# reuse existing common glue) — never block on these
_NON_UI = re.compile(r"\b(logged in|log out|logout|logs? in|navigat|home screen|"
                    r"is initiated|reviewing|parameters)\b", re.I)


def _needs_locator(step_text: str) -> bool:
    if _NON_UI.search(step_text):
        return False
    return bool(_UI_VERBS.search(step_text))


def _resolution_sources(txn: str | None, module: str | None) -> dict:
    """Everything the framework currently knows that could supply a locator."""
    facts = {"repository": "", "runtime_dom": "", "page_locators": ""}
    try:
        from . import recorder
        facts["repository"] = recorder.repository_for_prompt()
    except Exception:  # noqa: BLE001
        pass
    try:
        from . import capture
        facts["runtime_dom"] = capture.runtime_dom_for_prompt(txn)
    except Exception:  # noqa: BLE001
        pass
    try:
        from . import framework_scanner
        kb = framework_scanner.get_framework_knowledge()
        locs = []
        for pg in kb["pages"]:
            if not module or pg["module"] == module:
                locs += pg["locators"]
        facts["page_locators"] = " ".join(locs)
    except Exception:  # noqa: BLE001
        pass
    return facts


def evaluate(undefined_steps: list[str], txn: str | None, module: str | None) -> dict:
    """Decide the gate outcome.

    Returns:
      {
        "policy": "todo" | "strict",
        "ui_steps":        [steps that need a locator],
        "resolvable":      bool,   # does the framework have ANY locator knowledge
                                   # source to draw on for these screens?
        "unresolved_steps":[ui steps with NO supporting locator source at all],
        "blocked": bool,           # strict + unresolved -> generation must halt
        "message": str,
      }
    """
    policy = getattr(config, "LOCATOR_POLICY", "todo")
    ui_steps = [s for s in undefined_steps if _needs_locator(s)]

    if not ui_steps:
        return {"policy": policy, "ui_steps": [], "resolvable": True,
                "unresolved_steps": [], "blocked": False,
                "message": "No new UI-interacting steps require locators."}

    sources = _resolution_sources(txn, module)
    have_any_source = bool(sources["repository"].strip() or sources["runtime_dom"].strip()
                           or sources["page_locators"].strip())

    # Per UI step: is there ANY plausible locator source mentioning its key noun?
    # (a lightweight signal — full element matching happens in generation).
    unresolved = []
    haystack = (sources["repository"] + " " + sources["runtime_dom"] + " "
                + sources["page_locators"]).lower()
    for step in ui_steps:
        nouns = [w for w in re.findall(r"[a-zA-Z]{4,}", step.lower())
                 if not _UI_VERBS.fullmatch(w)]
        if not any(n in haystack for n in nouns):
            unresolved.append(step)

    # strict policy blocks whenever at least one UI step has no locator source
    blocked = (policy == "strict") and bool(unresolved)

    if blocked:
        msg = (f"Locator discovery required: {len(unresolved)} new UI step(s) have no locator "
               "in the repository, runtime capture, or existing page objects. Record these "
               "screens (Locator Recorder) or run once with Capture Mode, then retry.")
    elif unresolved:
        msg = (f"{len(unresolved)} UI step(s) lack a known locator — generation will proceed "
               "with '// TODO QA: verify locator' markers (policy: todo).")
    else:
        msg = "All new UI steps have a supporting locator source."

    return {"policy": policy, "ui_steps": ui_steps, "resolvable": have_any_source,
            "unresolved_steps": unresolved, "blocked": blocked, "message": msg}
