# Capture Mode — Java integration (the ONLY framework change)

Everything else for Capture Mode is already built and tested on the Python
side. This one small, **additive** Java helper is what makes the framework push
runtime screen captures to the orchestrator. It touches nothing existing — you
add one new file and a few one-line calls.

You do not need to understand the Java; paste it exactly as written.

---

## 1. Add ONE new class

Create this file in your framework:

`src/test/java/com/nbc/utils/CaptureAgent.java`

```java
package com.nbc.utils;

import org.openqa.selenium.OutputType;
import org.openqa.selenium.TakesScreenshot;
import org.openqa.selenium.WebDriver;

import java.net.URI;
import java.net.http.HttpClient;
import java.net.http.HttpRequest;
import java.net.http.HttpResponse;
import java.util.Base64;

/**
 * Capture Mode agent. Pushes a runtime screen capture (screenshot + HTML +
 * metadata) to the Python orchestrator. Fully self-contained, no external
 * libraries beyond the JDK's built-in HttpClient (Java 11+). Silently no-ops
 * if capture is disabled or the orchestrator is unreachable, so it can NEVER
 * break a normal test run.
 *
 * Enable per run with a system property:
 *   -Dcapture.enabled=true -Dcapture.run=CR26020074 -Dcapture.txn=1045
 * (The orchestrator sets these automatically in Capture Mode; when absent,
 * every method below returns immediately and does nothing.)
 */
public final class CaptureAgent {

    private static final boolean ENABLED =
            Boolean.parseBoolean(System.getProperty("capture.enabled", "false"));
    private static final String ENDPOINT =
            System.getProperty("capture.endpoint", "http://127.0.0.1:8000/capture/ingest");
    private static final String RUN_ID = System.getProperty("capture.run", "");
    private static final String TXN    = System.getProperty("capture.txn", "");

    private static final HttpClient HTTP = HttpClient.newHttpClient();

    private CaptureAgent() {}

    /** Capture the current screen at a named checkpoint. Safe to call anywhere. */
    public static void capture(WebDriver driver, String checkpoint, String screenName) {
        if (!ENABLED || driver == null) return;
        try {
            String html = "";
            try { html = driver.getPageSource(); } catch (Exception ignored) {}

            String shot = "";
            try {
                shot = ((TakesScreenshot) driver).getScreenshotAs(OutputType.BASE64);
            } catch (Exception ignored) {}

            String url = "", title = "";
            try { url = driver.getCurrentUrl(); } catch (Exception ignored) {}
            try { title = driver.getTitle(); } catch (Exception ignored) {}

            String json = "{"
                + "\"run_id\":" + q(RUN_ID) + ","
                + "\"txn\":" + q(TXN) + ","
                + "\"checkpoint\":" + q(checkpoint) + ","
                + "\"html\":" + q(html) + ","
                + "\"screenshot_b64\":" + q(shot) + ","
                + "\"metadata\":{"
                    + "\"screen_name\":" + q(screenName) + ","
                    + "\"url\":" + q(url) + ","
                    + "\"title\":" + q(title)
                + "}}";

            HttpRequest req = HttpRequest.newBuilder(URI.create(ENDPOINT))
                    .header("Content-Type", "application/json")
                    .POST(HttpRequest.BodyPublishers.ofString(json))
                    .build();
            HTTP.sendAsync(req, HttpResponse.BodyHandlers.discarding());
        } catch (Exception ignored) {
            // capture must never fail a real test run
        }
    }

    /** Minimal JSON string escaping. */
    private static String q(String s) {
        if (s == null) return "\"\"";
        StringBuilder b = new StringBuilder("\"");
        for (int i = 0; i < s.length(); i++) {
            char c = s.charAt(i);
            switch (c) {
                case '"':  b.append("\\\""); break;
                case '\\': b.append("\\\\"); break;
                case '\n': b.append("\\n");  break;
                case '\r': b.append("\\r");  break;
                case '\t': b.append("\\t");  break;
                default:
                    if (c < 0x20) b.append(String.format("\\u%04x", (int) c));
                    else b.append(c);
            }
        }
        return b.append("\"").toString();
    }
}
```

